# Database
DATABASE_URL="postgresql://postgres:postgres_password@127.0.0.1:5432/slabhub?schema=public"
DATABASE_URL_TEST="postgresql://postgres:postgres_password@127.0.0.1:5432/slabhub_test?schema=public"

# API Server
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://64.23.242.93:8081

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
WEB_ORIGIN=http://localhost:3000

# Auth
SESSION_COOKIE_NAME=slabhub_session
SESSION_TTL_DAYS=30
OTP_TTL_MINUTES=10
OTP_SECRET=your-secure-otp-secret-here

# App Store review demo credentials.
# Set BOTH on production only. When set, OTP for this email is bypassed —
# request-otp returns ok without sending mail; verify-otp accepts the
# configured code without checking the database. Leave unset on dev.
APP_REVIEW_EMAIL=
APP_REVIEW_OTP=

# Resend
RESEND_API_KEY=re_123456789
# MAIL_FROM="SlabHub <auth@slabhub.gg>" # Optional, defaults to SlabHub <auth@slabhub.gg>

# S3 Storage (DigitalOcean Spaces)
S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
S3_REGION=nyc3
S3_BUCKET=slabhub-files-dev
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_PUBLIC_BASE_URL=https://slabhub-files-dev.nyc3.digitaloceanspaces.com
S3_CDN_BASE_URL=https://slabhub-files-dev.nyc3.cdn.digitaloceanspaces.com
S3_FORCE_PATH_STYLE=false
S3_UPLOAD_MAX_BYTES=15728640 # 15MB
S3_ALLOWED_MIME=image/jpeg,image/png,image/webp

# Facebook OAuth
FACEBOOK_APP_ID=your_app_id
FACEBOOK_APP_SECRET=your_app_secret
EXPO_PUBLIC_FACEBOOK_APP_ID=your_app_id

# Apple Auth
APPLE_BUNDLE_ID=gg.slabhub.crm

# Sentry
SENTRY_DSN=

# Google Gemini AI (slab image recognition)
GEMINI_API_KEY=
# Vision-capable Gemini model used for slab recognition + disambiguation.
# Trade-off cost vs quality: gemini-2.5-pro > gemini-2.5-flash > gemini-2.5-flash-lite (default).
GEMINI_RECOGNITION_MODEL=gemini-2.5-flash-lite
