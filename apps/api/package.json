{
    "name": "@slabhub/api",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "build": "nest build",
        "dev": "nest start --watch",
        "start": "nest start",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "console": "ts-node -r tsconfig-paths/register src/console.ts",
        "justtcg:sync:dictionaries": "npm run console -- justtcg:sync:dictionaries",
        "justtcg:sync:catalog": "npm run console -- justtcg:sync:catalog",
        "justtcg:sync:all": "npm run console -- justtcg:sync:all",
        "pricecharting:crawl:onepiece": "npm run console -- pricecharting:crawl:onepiece",
        "inventory:sync:prices": "npm run console -- inventory:sync:prices",
        "grading:test-recognition": "npm run console -- grading:test-recognition"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.992.0",
        "@aws-sdk/s3-request-presigner": "^3.992.0",
        "@google/generative-ai": "^0.24.1",
        "@nestjs/axios": "^4.0.1",
        "@nestjs/common": "^11.0.0",
        "@nestjs/config": "^4.0.2",
        "@nestjs/core": "^11.0.0",
        "@nestjs/platform-express": "^11.0.0",
        "@nestjs/serve-static": "^5.0.4",
        "@nestjs/swagger": "^11.2.6",
        "@nestjs/throttler": "^6.5.0",
        "@prisma/client": "^6.2.0",
        "@sentry/nestjs": "^10.38.0",
        "@types/mime-types": "^3.0.1",
        "axios": "^1.13.2",
        "cheerio": "^1.2.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "cookie-parser": "^1.4.7",
        "https-proxy-agent": "^7.0.6",
        "mime-types": "^3.0.2",
        "nest-commander": "^3.20.1",
        "reflect-metadata": "^0.2.2",
        "resend": "^6.9.2",
        "rxjs": "^7.8.1",
        "sharp": "^0.34.5",
        "swagger-ui-express": "^5.0.1",
        "zod": "^4.3.5"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^5.0.0",
        "@types/jest": "^29.5.14",
        "@types/multer": "^2.0.0",
        "@types/node": "^22.10.0",
        "@typescript-eslint/eslint-plugin": "^8.18.0",
        "@typescript-eslint/parser": "^8.18.0",
        "eslint": "^9.16.0",
        "jest": "^29.7.0",
        "prisma": "^6.2.0",
        "source-map-support": "^0.5.21",
        "ts-jest": "^29.2.5",
        "ts-loader": "^9.5.1",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.7.0"
    }
}