generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// User account
model User {
  id                 String          @id @default(cuid())
  email              String          @unique
  emailVerifiedAt    DateTime?
  facebookVerifiedAt DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  inventoryItems     InventoryItem[]
  sellerProfile      SellerProfile?
  sessions           Session[]
  oauthIdentities    OAuthIdentity[]
  invites            Invite[]
  acceptedInvites    InviteAcceptance[]
}

/// OTP codes for email verification
model OtpChallenge {
  id            String    @id @default(cuid())
  email         String
  codeHash      String
  salt          String?
  expiresAt     DateTime
  consumedAt    DateTime?
  attempts      Int       @default(0)
  lastAttemptAt DateTime?
  createdAt     DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}

/// Session record for secure authentication
model Session {
  id               String    @id @default(cuid())
  userId           String
  sessionTokenHash String    @unique
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?
  userAgent        String?
  ip               String?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/// Seller profile - one per user for MVP
model SellerProfile {
  id               String          @id @default(cuid())
  handle           String          @unique
  shopName         String
  isActive         Boolean         @default(true)
  location         String          @default("")
  paymentsAccepted String[]
  meetupsEnabled   Boolean         @default(false)
  shippingEnabled  Boolean         @default(false)
  fulfillmentOptions String[]      @default([])
  socials          Json            @default("{}")
  wishlistText     String          @default("")
  referenceLinks   Json            @default("[]")
  upcomingEvents   Json            @default("[]")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  userId           String?         @unique
  avatarId         String?
  inventoryItems   InventoryItem[]
  user             User?           @relation(fields: [userId], references: [id])
  avatarMedia      Media?          @relation("AvatarMedia", fields: [avatarId], references: [id])

  @@index([handle])
  @@index([userId])
}

/// Global card catalog - One Piece TCG cards
model CardProfile {
  id              String           @id
  name            String
  set             String
  rarity          String
  cardNumber      String
  imageUrl        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  cardVariants    CardVariant[]
  pricingSnapshot PricingSnapshot?

  @@index([name])
  @@index([set])
  @@index([cardNumber])
}

/// Card variants - specific print variants of a base card
model CardVariant {
  id             String          @id @default(cuid())
  cardId         String
  variantType    VariantType
  language       Language
  imageUrl       String
  name           String
  setName        String
  setNumber      String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  card           CardProfile     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  inventoryItems InventoryItem[]

  @@unique([cardId, variantType, language])
  @@index([cardId])
}

/// Global pricing per CardProfile - one snapshot per card for MVP
model PricingSnapshot {
  id            String      @id @default(cuid())
  cardProfileId String      @unique
  rawPrice      Decimal     @db.Decimal(10, 2)
  sealedPrice   Decimal?    @db.Decimal(10, 2)
  source        String      @default("Mock:TCGPlayer")
  updatedAt     DateTime    @updatedAt
  cardProfile   CardProfile @relation(fields: [cardProfileId], references: [id], onDelete: Cascade)

  @@index([cardProfileId])
}

/// Inventory items - belongs to a seller
model InventoryItem {
  id                        String                   @id @default(cuid())
  sellerId                  String?
  itemType                  ItemType
  cardVariantId             String?
  productName               String?
  productType               ProductType?
  language                  String?
  setName                   String?
  edition                   String?
  integrity                 SealedIntegrity?
  configuration             Json?
  gradeProvider             GradeProvider?
  gradeValue                String?
  certNumber                String?
  gradingCost               Decimal?                 @db.Decimal(10, 2)
  slabImages                Json?                    @default("{}")
  previousCertNumbers       String[]                 @default([])
  condition                 Condition?
  quantity                  Int                      @default(1)
  stage                     InventoryStage           @default(ACQUIRED)
  listingPrice              Decimal?                 @db.Decimal(10, 2)
  acquisitionPrice          Decimal?                 @db.Decimal(10, 2)
  acquisitionDate           DateTime?
  acquisitionSource         String?
  storageLocation           String?
  notes                     String?
  marketPriceSnapshot       Decimal?                 @db.Decimal(10, 2)
  marketPriceLastSaleDate   DateTime?
  photos                    Json                     @default("[]") // Still used for backward compatibility or multiple media IDs
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  certificationNumber       String?
  cardNumber                String?
  setCode                   String?
  gradingMeta               Json?
  refPriceChartingProductId String?
  userId                    String
  sellingDescription        String?
  sortOrder                 Int                      @default(0)
  cardVariant               CardVariant?             @relation(fields: [cardVariantId], references: [id])
  refPriceChartingProduct   RefPriceChartingProduct? @relation(fields: [refPriceChartingProductId], references: [id])
  seller                    SellerProfile?           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  user                      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Media references
  frontMediaId String?
  backMediaId  String?
  frontMedia   Media?  @relation("FrontMedia", fields: [frontMediaId], references: [id])
  backMedia    Media?  @relation("BackMedia", fields: [backMediaId], references: [id])

  @@index([sellerId])
  @@index([userId])
  @@index([stage])
  @@index([itemType])
  @@index([cardVariantId])
  @@index([refPriceChartingProductId])
  @@index([certificationNumber])
}

model RefGame {
  id              String    @id @default(cuid())
  externalId      String    @unique
  name            String
  slug            String?
  sourceUpdatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([externalId])
}

model RefSet {
  id              String    @id @default(cuid())
  externalId      String    @unique
  name            String
  code            String?
  slug            String?
  gameExternalId  String?
  releaseDate     DateTime?
  sourceUpdatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([externalId])
  @@index([gameExternalId])
}

model RefRarity {
  id              String    @id @default(cuid())
  externalId      String    @unique
  name            String
  code            String?
  sourceUpdatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([externalId])
}

model RefCondition {
  id              String    @id @default(cuid())
  externalId      String    @unique
  name            String
  abbreviation    String?
  sourceUpdatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([externalId])
}

model RefLanguage {
  id              String    @id @default(cuid())
  externalId      String    @unique
  name            String
  code            String?
  sourceUpdatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([externalId])
}

model RefPriceChartingProduct {
  id              String               @id @default(cuid())
  productUrl      String               @unique
  tcgPlayerId     Int?
  priceChartingId Int?
  cardNumber      String?
  details         Json
  categorySlug    String?
  setSlug         String?
  productSlug     String?
  scrapedAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  localImagePath  String?
  imageUrl        String?
  setId           String?
  productType     String?
  title           String?
  rawPrice        Decimal?             @db.Decimal(10, 2)
  sealedPrice     Decimal?             @db.Decimal(10, 2)
  grade10Price    Decimal?             @db.Decimal(10, 2)
  grade7Price     Decimal?             @db.Decimal(10, 2)
  grade8Price     Decimal?             @db.Decimal(10, 2)
  grade95Price    Decimal?             @db.Decimal(10, 2)
  grade9Price     Decimal?             @db.Decimal(10, 2)
  priceSource     String?
  priceUpdatedAt  DateTime?
  lastParsedAt    DateTime?
  inventoryItems  InventoryItem[]
  sales           PriceChartingSales[]
  set             RefPriceChartingSet? @relation(fields: [setId], references: [id])

  @@index([tcgPlayerId])
  @@index([priceChartingId])
  @@index([cardNumber])
  @@index([setId])
}

model PriceChartingSales {
  id         String                  @id @default(cuid())
  productId  String
  date       DateTime
  title      String
  price      Decimal                 @db.Decimal(10, 2)
  source     String
  link       String?
  grade      String?
  createdAt  DateTime                @default(now())
  lastSeenAt DateTime                @default(now())
  product    RefPriceChartingProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([date])
}

model RefPriceChartingSet {
  id        String                    @id @default(cuid())
  name      String                    @unique
  code      String?
  slug      String?                   @unique
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt
  products  RefPriceChartingProduct[]
}

model RefPrinting {
  id              String    @id @default(cuid())
  externalId      String    @unique
  name            String
  code            String?
  sourceUpdatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([externalId])
}

model RefProduct {
  id               String    @id @default(cuid())
  externalId       String    @unique
  name             String
  number           String?
  imageUrl         String?
  setExternalId    String?
  rarityExternalId String?
  gameExternalId   String?
  sourceUpdatedAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  tcgplayerId      String?
  justTcgData      Json?
  priceSource      String?
  priceUpdatedAt   DateTime?
  rawPrice         Decimal?  @db.Decimal(10, 2)
  sealedPrice      Decimal?  @db.Decimal(10, 2)
  grade10Price     Decimal?  @db.Decimal(10, 2)
  grade7Price      Decimal?  @db.Decimal(10, 2)
  grade8Price      Decimal?  @db.Decimal(10, 2)
  grade95Price     Decimal?  @db.Decimal(10, 2)
  grade9Price      Decimal?  @db.Decimal(10, 2)

  @@index([externalId])
  @@index([setExternalId])
  @@index([rarityExternalId])
  @@index([gameExternalId])
}

model RefSyncProgress {
  id             String   @id @default(cuid())
  mappingName    String   @unique
  offset         Int      @default(0)
  page           Int      @default(1)
  cursor         String?
  totalItems     Int?
  processedItems Int      @default(0)
  status         String   @default("IDLE")
  lastError      String?
  lastSyncAt     DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum InventoryStage {
  ACQUIRED
  IN_TRANSIT
  BEING_GRADED
  AUTHENTICATED
  IN_STOCK
  LISTED
  SOLD
  ARCHIVED
}

enum ItemType {
  SINGLE_CARD_RAW
  SINGLE_CARD_GRADED
  SEALED_PRODUCT
}

enum GradeProvider {
  PSA
  BGS
  CGC
  ARS
  SGC
}

enum Condition {
  NM
  LP
  MP
  HP
  DMG
}

enum ProductType {
  BOOSTER_BOX
  BOOSTER_PACK
  STARTER_DECK
  ILLUSTRATION_BOX
  MINI_TIN
  PREMIUM_BOX
  GIFT_BOX
  ANNIVERSARY_SET
  PROMO_PACK
  TOURNAMENT_KIT
  CASE
  BUNDLE
  OTHER
}

enum SealedIntegrity {
  MINT
  MINOR_DENTS
  DAMAGED
  OPENED
}

enum VariantType {
  NORMAL
  ALTERNATE_ART
  PARALLEL_FOIL
}

enum Language {
  JP
  EN
}

model Media {
  id          String   @id @default(cuid())
  hash        String   @unique // sha256 hex of content
  ext         String? // "jpg", "png", "webp" (derived)
  mimeType    String
  sizeBytes   Int
  bucket      String
  key         String   @unique // object key in bucket
  etag        String? // returned by S3/Spaces
  width       Int? // optional (images)
  height      Int? // optional (images)
  sourceUrl   String? // if ingested from remote (pricecharting)
  ownerUserId String? // optional link to user
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  frontInventoryItems InventoryItem[] @relation("FrontMedia")
  backInventoryItems  InventoryItem[] @relation("BackMedia")
  avatarSellerProfiles SellerProfile[] @relation("AvatarMedia")

  @@index([ownerUserId])
  @@index([createdAt])
}

model WaitlistParticipant {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  @@index([email])
}

/// External OAuth identities (Facebook, etc.)
model OAuthIdentity {
  id             String @id @default(cuid())
  provider       String // e.g., "facebook"
  providerUserId String // Provider-specific user id (e.g., Facebook user id)
  userId         String
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  email       String? // email returned by provider (normalized)
  profileUrl  String? // Social profile link to show publicly
  profileData Json // any useful fields returned from provider
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([provider, providerUserId])
  @@index([userId])
}

model Invite {
  id            String   @id @default(cuid())
  inviterUserId String
  inviter       User     @relation(fields: [inviterUserId], references: [id], onDelete: Cascade)

  tokenHash     String   @unique
  createdAt     DateTime @default(now())
  expiresAt     DateTime
  revokedAt     DateTime?
  maxUses       Int      @default(1)
  usedCount     Int      @default(0)

  acceptedUsers InviteAcceptance[]

  @@index([inviterUserId])
  @@index([expiresAt])
}

model InviteAcceptance {
  id         String   @id @default(cuid())
  inviteId   String
  invite     Invite   @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  invitedUserId String
  invitedUser   User     @relation(fields: [invitedUserId], references: [id], onDelete: Cascade)

  acceptedAt DateTime @default(now())
  invitedEmailMasked String?

  @@unique([inviteId, invitedUserId])
  @@index([invitedUserId])
}
