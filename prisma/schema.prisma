generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// User account
model User {
  id                 String             @id @default(cuid())
  admin              Int                @default(0)
  email              String             @unique
  emailVerifiedAt    DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  facebookVerifiedAt DateTime?
  inventoryHistory   InventoryHistory[]
  inventoryItems     InventoryItem[]
  invites            Invite[]
  acceptedInvites    InviteAcceptance[]
  oauthIdentities    OAuthIdentity[]
  sellerProfile      SellerProfile?
  sessions           Session[]
  workflowStatuses   WorkflowStatus[]
}

/// OTP codes for email verification
model OtpChallenge {
  id            String    @id @default(cuid())
  email         String
  codeHash      String
  salt          String?
  expiresAt     DateTime
  consumedAt    DateTime?
  attempts      Int       @default(0)
  lastAttemptAt DateTime?
  createdAt     DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}

/// Session record for secure authentication
model Session {
  id               String    @id @default(cuid())
  userId           String
  sessionTokenHash String    @unique
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?
  userAgent        String?
  ip               String?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/// Seller profile - one per user for MVP
model SellerProfile {
  id                 String          @id @default(cuid())
  handle             String          @unique
  shopName           String
  isActive           Boolean         @default(false)
  paymentsAccepted   String[]
  meetupsEnabled     Boolean         @default(false)
  shippingEnabled    Boolean         @default(false)
  socials            Json            @default("{}")
  wishlistText       String          @default("")
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  userId             String?         @unique
  avatarId           String?
  referenceLinks     Json            @default("[]")
  upcomingEvents     Json            @default("[]")
  fulfillmentOptions String[]        @default([])
  location           String          @default("")
  discordWebhookUrl  String?
  inventoryItems     InventoryItem[]
  avatarMedia        Media?          @relation("AvatarMedia", fields: [avatarId], references: [id])
  user               User?           @relation(fields: [userId], references: [id])
  shopEvents         ShopEvent[]

  @@index([handle])
  @@index([userId])
}

/// Global card catalog - One Piece TCG cards
model CardProfile {
  id              String           @id
  name            String
  set             String
  rarity          String
  cardNumber      String
  imageUrl        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  cardVariants    CardVariant[]
  pricingSnapshot PricingSnapshot?

  @@index([name])
  @@index([set])
  @@index([cardNumber])
}

/// Card variants - specific print variants of a base card
model CardVariant {
  id             String          @id @default(cuid())
  cardId         String
  variantType    VariantType
  language       Language
  imageUrl       String
  name           String
  setName        String
  setNumber      String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  card           CardProfile     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  inventoryItems InventoryItem[]

  @@unique([cardId, variantType, language])
  @@index([cardId])
}

/// Global pricing per CardProfile - one snapshot per card for MVP
model PricingSnapshot {
  id            String      @id @default(cuid())
  cardProfileId String      @unique
  rawPrice      Decimal     @db.Decimal(10, 2)
  sealedPrice   Decimal?    @db.Decimal(10, 2)
  source        String      @default("Mock:TCGPlayer")
  updatedAt     DateTime    @updatedAt
  cardProfile   CardProfile @relation(fields: [cardProfileId], references: [id], onDelete: Cascade)

  @@index([cardProfileId])
}

/// Inventory items - belongs to a seller
model InventoryItem {
  id                        String                   @id @default(cuid())
  sellerId                  String?
  itemType                  ItemType
  cardVariantId             String?
  productName               String?
  productType               ProductType?
  language                  String?
  setName                   String?
  edition                   String?
  integrity                 SealedIntegrity?
  configuration             Json?
  gradeProvider             GradeProvider?
  gradeValue                String?
  certNumber                String?
  gradingCost               Decimal?                 @db.Decimal(10, 2)
  slabImages                Json?                    @default("{}")
  previousCertNumbers       String[]                 @default([])
  condition                 Condition?
  quantity                  Int                      @default(1)
  stage                     InventoryStage           @default(ACQUIRED)
  listingPrice              Decimal?                 @db.Decimal(10, 2)
  acquisitionPrice          Decimal?                 @db.Decimal(10, 2)
  acquisitionDate           DateTime?
  acquisitionSource         String?
  storageLocation           String?
  notes                     String?
  marketPriceSnapshot       Decimal?                 @db.Decimal(10, 2)
  photos                    Json                     @default("[]")
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  certificationNumber       String?
  gradingMeta               Json?
  refPriceChartingProductId String?
  userId                    String
  sellingDescription        String?
  sortOrder                 Int                      @default(0)
  backMediaId               String?
  frontMediaId              String?
  marketPriceLastSaleDate   DateTime?
  cardNumber                String?
  setCode                   String?
  statusId                  String?
  soldDate                  DateTime?
  soldPrice                 Decimal?                 @db.Decimal(10, 2)
  history                   InventoryHistory[]
  backMedia                 Media?                   @relation("BackMedia", fields: [backMediaId], references: [id])
  cardVariant               CardVariant?             @relation(fields: [cardVariantId], references: [id])
  frontMedia                Media?                   @relation("FrontMedia", fields: [frontMediaId], references: [id])
  refPriceChartingProduct   RefPriceChartingProduct? @relation(fields: [refPriceChartingProductId], references: [id])
  seller                    SellerProfile?           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  status                    WorkflowStatus?          @relation(fields: [statusId], references: [id])
  user                      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopEvents                ShopEvent[]

  @@index([sellerId])
  @@index([userId])
  @@index([stage])
  @@index([statusId])
  @@index([itemType])
  @@index([cardVariantId])
  @@index([refPriceChartingProductId])
  @@index([certificationNumber])
}

model WorkflowStatus {
  id           String          @id @default(cuid())
  name         String
  color        String?
  position     Int
  isEnabled    Boolean         @default(true)
  systemId     String?
  userId       String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  showOnKanban Boolean         @default(true)
  items        InventoryItem[]
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([position])
  @@index([userId, systemId])
}

model RefGame {
  id              String    @id @default(cuid())
  externalId      String    @unique
  name            String
  slug            String?
  sourceUpdatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([externalId])
}

model RefSet {
  id              String    @id @default(cuid())
  externalId      String    @unique
  name            String
  code            String?
  slug            String?
  gameExternalId  String?
  releaseDate     DateTime?
  sourceUpdatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([externalId])
  @@index([gameExternalId])
}

model RefPriceChartingProduct {
  id              String               @id @default(cuid())
  productUrl      String               @unique
  tcgPlayerId     Int?
  priceChartingId Int?
  cardNumber      String?
  details         Json
  categorySlug    String?
  setSlug         String?
  productSlug     String?
  scrapedAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  localImagePath  String?
  imageUrl        String?
  setId           String?
  productType     String?
  title           String?
  grade10Price    Decimal?             @db.Decimal(10, 2)
  grade7Price     Decimal?             @db.Decimal(10, 2)
  grade8Price     Decimal?             @db.Decimal(10, 2)
  grade95Price    Decimal?             @db.Decimal(10, 2)
  grade9Price     Decimal?             @db.Decimal(10, 2)
  priceSource     String?
  priceUpdatedAt  DateTime?
  rawPrice        Decimal?             @db.Decimal(10, 2)
  sealedPrice     Decimal?             @db.Decimal(10, 2)
  lastParsedAt    DateTime?
  inventoryItems  InventoryItem[]
  sales           PriceChartingSales[]
  set             RefPriceChartingSet? @relation(fields: [setId], references: [id])

  @@index([tcgPlayerId])
  @@index([priceChartingId])
  @@index([cardNumber])
  @@index([setId])
}

model PriceChartingSales {
  id         String                  @id @default(cuid())
  productId  String
  date       DateTime
  title      String
  price      Decimal                 @db.Decimal(10, 2)
  source     String
  link       String?
  grade      String?
  createdAt  DateTime                @default(now())
  lastSeenAt DateTime                @default(now())
  product    RefPriceChartingProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([date])
}

model RefPriceChartingSet {
  id        String                    @id @default(cuid())
  name      String                    @unique
  slug      String?                   @unique
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt
  code      String?
  products  RefPriceChartingProduct[]
}

model RefPrinting {
  id              String    @id @default(cuid())
  externalId      String    @unique
  name            String
  code            String?
  sourceUpdatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([externalId])
}

model RefProduct {
  id               String    @id @default(cuid())
  externalId       String    @unique
  name             String
  number           String?
  imageUrl         String?
  setExternalId    String?
  rarityExternalId String?
  gameExternalId   String?
  sourceUpdatedAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  tcgplayerId      String?
  justTcgData      Json?
  priceSource      String?
  priceUpdatedAt   DateTime?
  rawPrice         Decimal?  @db.Decimal(10, 2)
  sealedPrice      Decimal?  @db.Decimal(10, 2)
  grade10Price     Decimal?  @db.Decimal(10, 2)
  grade7Price      Decimal?  @db.Decimal(10, 2)
  grade8Price      Decimal?  @db.Decimal(10, 2)
  grade95Price     Decimal?  @db.Decimal(10, 2)
  grade9Price      Decimal?  @db.Decimal(10, 2)

  @@index([externalId])
  @@index([setExternalId])
  @@index([rarityExternalId])
  @@index([gameExternalId])
}

model RefSyncProgress {
  id             String   @id @default(cuid())
  mappingName    String   @unique
  offset         Int      @default(0)
  page           Int      @default(1)
  cursor         String?
  totalItems     Int?
  processedItems Int      @default(0)
  status         String   @default("IDLE")
  lastError      String?
  lastSyncAt     DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Media {
  id                   String          @id @default(cuid())
  hash                 String          @unique
  ext                  String?
  mimeType             String
  sizeBytes            Int
  bucket               String
  key                  String          @unique
  etag                 String?
  width                Int?
  height               Int?
  sourceUrl            String?
  ownerUserId          String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  backInventoryItems   InventoryItem[] @relation("BackMedia")
  frontInventoryItems  InventoryItem[] @relation("FrontMedia")
  avatarSellerProfiles SellerProfile[] @relation("AvatarMedia")

  @@index([ownerUserId])
  @@index([createdAt])
}

model WaitlistParticipant {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  @@index([email])
}

/// External OAuth identities (Facebook, etc.)
model OAuthIdentity {
  id             String   @id @default(cuid())
  provider       String
  providerUserId String
  userId         String
  email          String?
  profileUrl     String?
  profileData    Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

model Invite {
  id            String             @id @default(cuid())
  inviterUserId String
  tokenHash     String             @unique
  createdAt     DateTime           @default(now())
  expiresAt     DateTime
  revokedAt     DateTime?
  maxUses       Int                @default(1)
  usedCount     Int                @default(0)
  inviter       User               @relation(fields: [inviterUserId], references: [id], onDelete: Cascade)
  acceptedUsers InviteAcceptance[]

  @@index([inviterUserId])
  @@index([expiresAt])
}

model InviteAcceptance {
  id                 String   @id @default(cuid())
  inviteId           String
  invitedUserId      String
  acceptedAt         DateTime @default(now())
  invitedEmailMasked String?
  invite             Invite   @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  invitedUser        User     @relation(fields: [invitedUserId], references: [id], onDelete: Cascade)

  @@unique([inviteId, invitedUserId])
  @@index([invitedUserId])
}

model InventoryHistory {
  id           String          @id @default(cuid())
  itemId       String
  userId       String
  type         String
  fromStage    InventoryStage?
  toStage      InventoryStage?
  fromStatusId String?
  toStatusId   String?
  notes        String?
  createdAt    DateTime        @default(now())
  item         InventoryItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([userId])
}

model ShopEvent {
  id              String         @id @default(cuid())
  sellerProfileId String
  type            ShopEventType
  itemId          String?
  referrer        String?
  channel         String?
  ipHash          String?
  userAgent       String?
  createdAt       DateTime       @default(now())
  countryCode     String?
  ip              String?
  item            InventoryItem? @relation(fields: [itemId], references: [id])
  sellerProfile   SellerProfile  @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)

  @@index([sellerProfileId])
  @@index([createdAt])
  @@index([type])
}


enum InventoryStage {
  ACQUIRED
  IN_TRANSIT
  BEING_GRADED
  AUTHENTICATED
  IN_STOCK
  LISTED
  SOLD
  ARCHIVED
}

enum ItemType {
  SINGLE_CARD_RAW
  SINGLE_CARD_GRADED
  SEALED_PRODUCT
}

enum GradeProvider {
  PSA
  BGS
  CGC
  ARS
  SGC
  OTHER
}

enum Condition {
  NM
  LP
  MP
  HP
  DMG
}

enum ProductType {
  BOOSTER_BOX
  BOOSTER_PACK
  STARTER_DECK
  ILLUSTRATION_BOX
  MINI_TIN
  PREMIUM_BOX
  GIFT_BOX
  ANNIVERSARY_SET
  PROMO_PACK
  TOURNAMENT_KIT
  CASE
  BUNDLE
  OTHER
}

enum SealedIntegrity {
  MINT
  MINOR_DENTS
  DAMAGED
  OPENED
}

enum VariantType {
  NORMAL
  ALTERNATE_ART
  PARALLEL_FOIL
}

enum Language {
  JP
  EN
}

enum ShopEventType {
  VIEW_SHOP
  VIEW_ITEM
  INQUIRY_START
  INQUIRY_COMPLETE
}
